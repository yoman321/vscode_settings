// Place your key bindings in this file to override the defaults
[
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b\r"
        },
        "when": "terminalFocus"
    },

    // --- Explorer (directory tree) vim-style navigation ---
    {
        "key": "j",
        "command": "list.focusDown",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "k",
        "command": "list.focusUp",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "l",
        "command": "list.select",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "h",
        "command": "list.collapse",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "n",
        "command": "explorer.newFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "shift+n",
        "command": "explorer.newFolder",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // --- Terminal: switch between terminals ---
    {
        "key": "shift+l",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus"
    },
    {
        "key": "shift+h",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+shift+l",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus && isMac"
    },
    {
        "key": "cmd+shift+h",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus && isMac"
    },
    {
        "key": "alt+shift+l",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus && isWindows"
    },
    {
        "key": "alt+shift+h",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus && isWindows"
    },
    {
        "key": "shift+cmd+n",
        "command": "workbench.action.terminal.new",
        "when": "terminalFocus && isMac"
    },
    {
        "key": "shift+cmd+d",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus && isMac"
    },
    {
        "key": "shift+alt+n",
        "command": "workbench.action.terminal.new",
        "when": "terminalFocus && isWindows"
    },
    {
        "key": "shift+alt+d",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus && isWindows"
    },
    // --- Escape: close source control (commit) panel and return to editor ---
    {
        "key": "escape",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.closeSidebar",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "when": "scmInputBoxFocus"
    },
    {
        "key": "escape",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.closeSidebar",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "when": "focusedView == 'workbench.scm'"
    },
    // --- Escape: close Explorer and return to editor ---
    {
        "key": "escape",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.closeSidebar",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "when": "filesExplorerFocus && !inputFocus"
    },

    // --- Escape: close search/debug and return to editor ---
    {
        "key": "escape",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.closeSidebar",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "when": "sideBarFocus && !filesExplorerFocus && !inputFocus"
    },

    // --- Run & Debug panel shortcuts ---
    {
        "key": "r",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.debug.run",
                "workbench.action.closeSidebar",
                "workbench.action.terminal.focus"
            ]
        },
        "when": "sideBarFocus && !inputFocus"
    },
    {
        "key": "d",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.debug.start",
                "workbench.action.terminal.focus"
            ]
        },
        "when": "sideBarFocus && !inputFocus"
    },

    // --- Escape: close terminal/panel and return to editor ---
    {
        "key": "escape",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.closePanel",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "when": "terminalFocus || panelFocus"
    },
    // --- Escape: close search panel and return to editor ---
    {
        "key": "escape",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.closeSidebar",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "when": "searchViewletFocus"
    },
    // --- commit + push
    {
        "key": "cmd+enter",
        "command": "git.commitAndPush",
        "when": "scmInputIsFocused || scmInputBoxFocus"
    }
]